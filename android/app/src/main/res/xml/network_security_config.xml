<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Allow cleartext HTTP traffic only to local development machines.
        This does NOT affect production traffic (which must use HTTPS).
    -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- LAN dev machine -->
        <domain includeSubdomains="false">192.168.178.148</domain>
        <!-- Localhost variants for emulator / USB forwarding -->
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
